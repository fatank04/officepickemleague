# ---- Database (Neon Postgres) ----
# Create a free project at neon.tech → copy the POOLED connection string into DATABASE_URL
# and the DIRECT (non-pooled) string into DIRECT_URL.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ---- The Odds API (https://the-odds-api.com) ----
ODDS_API_KEY="your_odds_api_key"

# ---- NFL season ----
SEASON="2026"

# ---- Auth / sessions (sign cookie + hash PINs) ----
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change_me_to_a_long_random_string"

# ---- Cron protection (Bearer token on scheduled requests) ----
CRON_SECRET="change_me_too"

# ---- Twilio (SMS + voice). Optional until you turn messaging on. ----
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
# Phone to receive grading-gap alerts (E.164, e.g. +1412...)
ALERT_PHONE=""

# ---- Public base URL of the deployment (used by SMS/voice signature checks + links) ----
NEXT_PUBLIC_BASE_URL="https://officepickemleague.com"
